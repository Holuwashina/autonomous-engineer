#!/usr/bin/env sh
# Autonomous Engineer safety hook — pre-push.
# Deterministically enforces iron rules that were previously prompt-only:
#   1. Never push directly to a protected branch (open a PR instead).
#   2. Never force / non-fast-forward push to a protected branch.
#
# git supplies, on stdin, one line per ref being pushed:
#   <local ref> <local sha> <remote ref> <remote sha>
#
# Protected branches: see pre-commit (AE_PROTECTED_BRANCHES or ae.protectedBranches).

DEFAULT_PROTECTED="main master dev develop production release"
PROTECTED="${AE_PROTECTED_BRANCHES:-$(git config --get ae.protectedBranches 2>/dev/null)}"
[ -n "$PROTECTED" ] || PROTECTED="$DEFAULT_PROTECTED"

ZERO="0000000000000000000000000000000000000000"
status=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "${remote_ref:-}" ] || continue
  case "$remote_ref" in
    refs/heads/*) branch="${remote_ref#refs/heads/}" ;;
    *) continue ;;
  esac

  for p in $PROTECTED; do
    if [ "$branch" = "$p" ]; then
      echo "✗ Autonomous Engineer: pushing directly to protected branch '$branch' is blocked." >&2
      echo "  Push your feature branch and open a PR instead." >&2
      status=1
    fi
  done

  # Block force / non-fast-forward updates to ANY branch (catches rewrites of shared history).
  if [ "$remote_sha" != "$ZERO" ] && [ "$local_sha" != "$ZERO" ]; then
    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      echo "✗ Autonomous Engineer: non-fast-forward (force) push to '$branch' is blocked." >&2
      echo "  Rebasing/force-pushing shared history needs explicit human action." >&2
      status=1
    fi
  fi
done

[ "$status" -eq 0 ] || echo "  (Override for one push, discouraged: git push --no-verify)" >&2
exit $status
